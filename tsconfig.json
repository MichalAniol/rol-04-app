{
    "ts-node": {
        "require": [
            "tsconfig-paths/register"
        ]
    },
    "compilerOptions": {
        "module": "AMD",
        "target": "ES2020",
        "lib": ["esnext", "dom", "webworker"],
        "moduleResolution": "node",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "noImplicitAny": true,
        "removeComments": true,
        "preserveConstEnums": false,
        "sourceMap": false,
        "downlevelIteration": false,
        "outFile": "dist/index.js"
    },
    "files": [
        "src/global.ts",
        "src/console.ts",
        "src/axios.min.ts",
        "src/idb.ts",
        "src/storage.ts",
        "src/dom.ts",
        "src/core.ts",
        "src/initAndGetData/initAndGetData.ts",
        "src/serviceWorker.ts",
        "src/_index.ts",
    ],
    "exclude": [
        "node_modules"
    ]
}