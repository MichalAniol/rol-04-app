{
    "ts-node": {
        "require": [
            "tsconfig-paths/register"
        ]
    },
    "compilerOptions": {
        "module": "AMD",
        "target": "ES2020",
        "lib": ["esnext", "dom", "webworker"],
        "moduleResolution": "node",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "noImplicitAny": true,
        "removeComments": true,
        "preserveConstEnums": false,
        "sourceMap": false,
        "downlevelIteration": false,
        "outFile": "dist/index.js"
    },
    "files": [
        "src/cookie.ts",
        "src/idb.ts",
        "src/storage.ts",
        "src/core.ts",
        "src/dom.ts",
        "src/console.ts",
        "src/axios.min.ts",
        "src/utils/resize.ts",
        "src/utils/sleep.ts",
        "src/utils/radio.ts",
        "src/queries/responseCommand.ts",
        "src/queries/url.ts",
        "src/queries/global.ts",
        "src/queries/tests.ts",
        "src/queries/error.ts",
        "src/queries/secure/secure.ts",
        "src/queries/secure/secureTest.ts",
        "src/queries/user/checkId.ts",
        "src/queries/user/setId.ts",
        "src/queries/user/getQrCodeId.ts",
        "src/queries/user/setUserIdByQrCode.ts",
        "src/inputs/keys.ts",
        "src/inputs/touch.ts",
        "src/screens/starter/starter.ts",
        "src/screens/starter/run/user.ts",
        "src/screens/starter/run/run.ts",
        "src/screens/statistics/statistics.ts",
        "src/screens/learning/learning.ts",
        "src/screens/answers/answers.ts",
        "src/screens/settings/info/info.ts",
        "src/screens/settings/dataControl/dataControl.ts",
        "src/screens/settings/theme/theme.ts",
        "src/screens/settings/menu/menu.ts",
        "src/screens/settings/settings.ts",
        "src/tab/tab.ts",
        "src/tab/mobile/visible.ts",
        "src/tab/mobile/touch.ts",
        "src/tab/simpleMenu/simpleMenu.ts",
        "src/tab/mobile/mobile.ts",
        "src/modal/user/user.ts",
        "src/modal/error/error.ts",
        "src/modal/modal.ts",
        "src/tests/errorModal.ts",
        "src/serviceWorker.ts",
        "src/app.ts",
    ],
    "exclude": [
        "node_modules"
    ]
}